generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  uid           String   @id
  email         String   @unique
  skillLevel    Skill_Level?
  learningModes String[]
  hoursPerWeek  Int?
  name          String?
  createdAt     DateTime @default(now())

  userProjects        UserProjects[]
  entranceTestAttempt EntranceTestAttempt?
  @@index([email])
}

model Projects {
  id                String    @default(uuid()) @unique
  name              String
  tech_stack        String[]
  skill_level       Skill_Level
  estimated_minutes Int
  createdAt         DateTime  @default(now())

  learningPhases      LearningPhase[]
  userProjects        UserProjects[]
}

// ── Adaptive entrance test question pool ────────────────────────────────────
model EntranceQuestion {
  id             String     @default(uuid()) @unique
  question       String
  options        String[]   // always 4 entries
  correct_option Int        // 0-3 index
  explanation    String
  difficulty     Difficulty
  topic          String
  createdAt      DateTime   @default(now())
}

model EntranceTestAttempt {
  id           String      @default(uuid()) @unique
  user_email   String      @unique
  status       TestStatus  @default(in_progress)
  round        Int         @default(1)
  answers      Json        @default("[]")
  result_level Skill_Level?
  started_at   DateTime    @default(now())
  completed_at DateTime?

  user         User        @relation(fields: [user_email], references: [email])
}

enum Difficulty {
  easy
  intermediate
  advanced
}

enum TestStatus {
  in_progress
  completed
}

model UserProjects {
  id              String   @default(uuid()) @unique
  project_id      String
  user_email      String
  status          Status   @default(in_progress)
  current_phase   Int      @default(0)
  started_at      DateTime @default(now())
  completed_at    DateTime?
  
  user            User @relation(fields: [user_email], references: [email])
  projects        Projects @relation(fields: [project_id], references: [id])
}

model LearningPhase {
  id                String    @default(uuid()) @unique
  project_id        String
  title             String
  description       String
  concepts          String[]
  goal              Json?
  phase_number      Int
  phase_status      PhaseStatus   @default(locked)
  estimated_minutes Int
  createdAt         DateTime  @default(now())
  
  project         Projects @relation(fields: [project_id], references: [id])
  resources       Resources[]
  knowledgeChecks KnowledgeChecks[]
}

model KnowledgeChecks {
  id                String    @default(uuid()) @unique
  phase_id          String
  question          String
  correct_answer    String?
  explanation       String
  question_type     Question_Type

  learningPhase     LearningPhase @relation(fields: [phase_id], references: [id])
}

model Resources {
  id                String     @default(uuid()) @unique
  phase_id          String
  type              String
  title             String
  url               String
  duration_minutes  Int
  provider          String
  timestamps        Json?
  quality_score     Float

  learningPhase     LearningPhase @relation(fields: [phase_id], references: [id])
}

enum Skill_Level {
  beginner
  intermediate
  advanced
}

enum Status {
  in_progress
  completed
  abandoned
}

enum Question_Type {
  code_completion
  multiple_choice
  debug
}

enum PhaseStatus {
  in_progress
  completed
  locked
}